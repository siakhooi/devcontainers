{
  "name": "RPM Development Dev Container",
  "image": "siakhooi/devcontainer:rpm",
  "remoteUser": "maui",
  "containerUser": "maui",
  "updateRemoteUserUID": true,
  "features": {},
  "customizations": {
    "vscode": {
      "extensions": [
        "github.copilot",
        "github.copilot-chat",
        "lfm.vscode-makefile-term",
        "redhat.vscode-yaml",
        "mkhl.shfmt",
        "timonwong.shellcheck",
        "foxundermoon.shell-format",
        "github.vscode-github-actions"
      ]
    }
  },
  "mounts": [
    "source=${localEnv:HOME}${localEnv:USERPROFILE}/.ssh,target=/home/maui/.ssh,type=bind,consistency=cached",
    "source=/var/run/docker.sock,target=/var/run/docker.sock,type=bind"
  ],
  "postStartCommand": "sudo chmod 666 /var/run/docker.sock || true",
  "remoteEnv": {
    "LOCAL_WORKSPACE_FOLDER": "${localWorkspaceFolder}"
  }
}